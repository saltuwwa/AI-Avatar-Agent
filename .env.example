# Шаблон для .env (БЕЗ реальных ключей). Скопируйте в .env и заполните значения.

# --- OpenAI: чат (tool calling), vision, при ASR_BACKEND=openai ещё и Whisper API ---
OPENAI_API_KEY=

OPENAI_MODEL=gpt-4o-mini
# Пусто = та же модель; отдельная vision-модель для skill по фото (опционально)
OPENAI_VISION_MODEL=

# --- fal.ai: MiniMax voice clone + TTS, Creatify Aurora ---
FAL_KEY=

MINIMAX_TTS_MODEL=fal-ai/minimax/speech-02-turbo
MINIMAX_LANGUAGE_BOOST=auto
MINIMAX_TTS_SPEED=1.12
MINIMAX_PREVIEW_TEXT=

# --- ASR: local = Whisper (transformers) | openai = whisper-1 API ---
ASR_BACKEND=local
ASR_MODEL_ID=openai/whisper-small
# Для лучшего казахского (тяжелее): abilmansplus/whisper-turbo-ksc2
ASR_DEVICE=auto
ASR_NUM_BEAMS=
ASR_LOCAL_LANGUAGE=kazakh
ASR_OPENAI_LANGUAGE=

# --- 2GIS (опционально) ---
# TWO_GIS_API_KEY=
# TWO_GIS_USE_PLAYWRIGHT=0
# TWO_GIS_CATALOG_URL=

# --- Голос: WAV ≥10 с в voice/ ---
VOICE_SAMPLE_FILENAME=my_voice_sample.wav

# --- Фото аватара (можно положить avatar/my_photo.jpg, 512×512+, фронтально) ---
# AVATAR_SOURCE_IMAGE=avatar/my_photo.jpg
AVATAR_SOURCE_IMAGE=photo_5377349946119492617_w.jpg
# AVATAR_IMAGE_512=
# CREATIFY_RESOLUTION=720p
CREATIFY_MODEL=fal-ai/creatify/aurora
CREATIFY_PROMPT=
